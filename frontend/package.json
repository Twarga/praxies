{
  "name": "praxis-frontend",
  "private": true,
  "version": "0.1.0",
  "description": "AI-assisted video journaling desktop app",
  "author": "Twarga",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "electron:dev": "sh -c 'unset ELECTRON_RUN_AS_NODE; exec electron electron/main.cjs'",
    "build": "vite build",
    "preview": "vite preview",
    "prepare:resources": "../scripts/prepare-electron-resources.sh",
    "electron:build": "npm run build && electron-builder",
    "electron:build:dir": "npm run build && electron-builder --dir",
    "release:linux": "../scripts/release-linux.sh"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/manrope": "^5.2.8",
    "@fontsource/spectral": "^5.2.8",
    "lucide-react": "^0.546.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.21",
    "electron": "^37.4.0",
    "electron-builder": "^26.8.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^7.1.12"
  }
}
