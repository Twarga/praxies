# Praxis env template — copy to `.env` for local dev. NEVER commit `.env`.
#
# Praxis stores the active OpenRouter key in ~/.config/praxis/config.json
# (set via Settings → AI in the app). This .env file is OPTIONAL and only
# exists for convenience if you want to keep a backup of your key outside
# the app config, or to bootstrap a key on a fresh machine.
#
# Backend code does NOT read from .env today. To wire it up, you'd need to
# extend backend/app/services/llm_client.py to fall back to the env var
# when config.openrouter.api_key is empty.

OPENROUTER_API_KEY=
